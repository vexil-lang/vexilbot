namespace scheduledrelease

enum BumpLevel : u8 {
  Patch @0
  Minor @1
  Major @2
}

enum ReleaseStatus : u8 {
  Pending   @0
  Confirmed @1
  Running   @2
  Done      @3
  Cancelled @4
}

message ScheduledRelease {
  id         @0 : string
  package    @1 : string
  bump       @2 : BumpLevel
  run_at     @3 : u64
  auto_run   @4 : bool
  status     @5 : ReleaseStatus
  created_at @6 : u64
  owner      @7 : string
  repo       @8 : string
}
