-- ScheduledRelease is defined here for documentation purposes.
-- Codegen is pending: the vexilc syntax for sub-byte fields (u1, u2) and enum
-- backing types may differ from the other schemas. Update and run codegen
-- when the CLI syntax is confirmed.

namespace scheduledrelease

enum BumpLevel : u2 {
    Patch = 0
    Minor = 1
    Major = 2
}

message ScheduledRelease {
    0: name   string
    1: run_at u64
    2: bump   BumpLevel
    3: kind   u1   -- 0=cargo 1=npm
}
